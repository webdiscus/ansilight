{
  "name": "ansilight",
  "version": "1.1.0",
  "description": "Truecolor syntax highlighting in the terminal with 200+ themes",
  "keywords": [
    "terminal",
    "cli",
    "syntax",
    "code",
    "highlight",
    "ansi"
  ],
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webdiscus/ansilight.git"
  },
  "type": "module",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./themes/*": {
      "types": "./theme.d.ts",
      "import": "./themes/*.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ansis": "^4.3.0",
    "highlight.js": "^11.11.1"
  }
}
